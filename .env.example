# ── MongoDB ──────────────────────────────────────────────────────────────────
# Get this from MongoDB Atlas: Connect → Drivers → copy the connection string
# Replace <password> with your database user password
MONGODB_URL=mongodb+srv://yourname:<password>@cluster0.xxxxx.mongodb.net/agrisense?retryWrites=true&w=majority

# ── JWT Auth ──────────────────────────────────────────────────────────────────
# Any long random string - run: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-this-with-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Gemini ────────────────────────────────────────────────────────────────────
# Get this from https://aistudio.google.com → Get API key → Create API key
GEMINI_API_KEY=your-gemini-api-key-here
